# Staging environment — copy to .env.staging and fill in values
# NEVER commit real values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_STAGING_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY
TWOCAPTCHA_API_KEY=YOUR_2CAPTCHA_KEY
POLK_COUNTY_USERNAME=YOUR_POLK_USERNAME
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE
PROOF_EMAIL=YOUR_PROOF_EMAIL
EPN_EMAIL=YOUR_EPN_EMAIL
EPN_PASSWORD=YOUR_EPN_PASSWORD
CREDENTIAL_ENCRYPTION_KEY=YOUR_64_CHAR_HEX_KEY
INTERNAL_API_KEY=YOUR_INTERNAL_API_KEY
NEXT_PUBLIC_APP_URL=https://staging.dartiq.dev
PORT=8080
AUTOMATION_QUEUE_RUNS=true
ENVIRONMENT=staging

# Durable workflow engine (default off)
WORKFLOW_ENGINE_EPN=false
WORKFLOW_WEBHOOK_SECRET=YOUR_WORKFLOW_WEBHOOK_SECRET

# Trigger.dev control plane
TRIGGER_SECRET_KEY=tr_dev_YOUR_KEY
TRIGGER_PROJECT_REF=proj_YOUR_PROJECT_REF
