# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
*.test.js

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
lib/docusign/private.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/tmp/

# env files — never commit secrets
.env.staging
.env.production
.env.local
.env*.local
!.env.staging.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# automation runtime artifacts (keep local, do not commit)
/automation/logs/
