FROM mcr.microsoft.com/playwright:v1.40.0-jammy
WORKDIR /app

COPY worker/package.json ./
RUN npm install

# Entry is named index.js in the container (/app/index.js)
COPY worker/noc-proof-erecord-worker.js ./index.js
COPY worker/handlers ./handlers
COPY worker/project-root.js ./

COPY automation/ ./automation/
COPY lib/ ./lib/
COPY workflows/ ./workflows/
COPY templates/ ./templates/

# Do not bake ENVIRONMENT/NODE_ENV here — Railway injects them at runtime.
# Restart survival: workflow railway-recovery + activity drain on each poll.
CMD ["node", "index.js"]
